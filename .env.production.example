# Template for the production .env file on cPanel.
#
# This file is NOT deployed automatically (excluded from the FTP transfer).
# Copy it to `.env` in the app's root directory on the server via cPanel
# File Manager, then fill in the real values below.

APP_NAME="Anufa Minerva"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://minerva.anufa-technologies.my.id

# Generate locally with: php artisan key:generate --show
APP_KEY=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# Random secret shared with the GitHub Actions DEPLOY_TOKEN secret.
# Generate with: php -r "echo bin2hex(random_bytes(32));"
DEPLOY_TOKEN=

# Creates the first admin login on the first /deploy/finalize run
# (skipped afterwards). Change the password after first login.
ADMIN_NAME="Admin"
ADMIN_USERNAME=admin
ADMIN_EMAIL=
ADMIN_PASSWORD=

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# cPanel "MySQL Databases" credentials
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cpaneluser_dbname
DB_USERNAME=cpaneluser_dbuser
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# No queue worker process on FTP-only shared hosting - run jobs inline.
QUEUE_CONNECTION=sync

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
